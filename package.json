{
  "name": "devpilot",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "axios": "^1.16.1"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-devpilotui": "cds watch --open com.devpilot.devpilotui/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "requires": {
      "db": {
        "kind": "sql"
      },
      "auth": {
        "kind": "dummy"
      },
      "ai": {
        "[development]": {
          "url": "http://localhost:8000"
        },
        "[production]": {
          "url": "https://devpilot-ai-dev.cfapps.us10-001.hana.ondemand.com"
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ]
}